<title>Carrot Quest — Детальный анализ продукта</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mermaid/10.6.1/mermaid.min.js"></script>
<style>
  :root {
    --primary: #6C47FF;
    --primary-light: #EDE9FF;
    --accent: #FF6B35;
    --green: #22C55E;
    --blue: #3B82F6;
    --gray-50: #F8FAFC;
    --gray-100: #F1F5F9;
    --gray-200: #E2E8F0;
    --gray-600: #475569;
    --gray-800: #1E293B;
    --text: #0F172A;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; color: var(--text); background: #fff; font-size: 14px; line-height: 1.6; }

  /* COVER */
  .cover {
    background: linear-gradient(135deg, #1a0533 0%, #3d1a7a 50%, #6C47FF 100%);
    color: white; padding: 80px 60px; min-height: 280px;
    display: flex; flex-direction: column; justify-content: center;
  }
  .cover .badge { background: rgba(255,255,255,0.15); display: inline-block; padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 24px; }
  .cover h1 { font-size: 42px; font-weight: 800; margin-bottom: 12px; }
  .cover .subtitle { font-size: 18px; opacity: 0.8; margin-bottom: 32px; }
  .cover .meta { display: flex; gap: 40px; flex-wrap: wrap; }
  .cover .meta-item { opacity: 0.7; font-size: 13px; }
  .cover .meta-item strong { display: block; opacity: 1; font-size: 15px; }

  /* LAYOUT */
  .container { max-width: 1200px; margin: 0 auto; padding: 0 40px; }
  section { padding: 60px 0; border-bottom: 1px solid var(--gray-200); }
  section:last-child { border-bottom: none; }

  /* HEADINGS */
  .section-header { margin-bottom: 36px; }
  .section-label { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--primary); background: var(--primary-light); padding: 4px 12px; border-radius: 4px; margin-bottom: 12px; }
  h2 { font-size: 30px; font-weight: 700; color: var(--gray-800); margin-bottom: 8px; }
  h3 { font-size: 20px; font-weight: 600; color: var(--gray-800); margin: 32px 0 16px; }
  h4 { font-size: 15px; font-weight: 600; color: var(--gray-800); margin: 20px 0 10px; }
  .section-desc { color: var(--gray-600); font-size: 15px; max-width: 720px; }

  /* CARDS */
  .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-top: 24px; }
  .card { background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 12px; padding: 24px; }
  .card-icon { font-size: 28px; margin-bottom: 12px; }
  .card h4 { margin: 0 0 8px; font-size: 16px; }
  .card p { color: var(--gray-600); font-size: 13px; }

  /* MODULE MAP */
  .module-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; margin-top: 24px; }
  .module-card { border-radius: 10px; padding: 20px; border-left: 4px solid; }
  .module-card.core { background: #EDE9FF; border-color: var(--primary); }
  .module-card.engagement { background: #FFF7ED; border-color: var(--accent); }
  .module-card.support { background: #ECFDF5; border-color: var(--green); }
  .module-card.analytics { background: #EFF6FF; border-color: var(--blue); }
  .module-card.settings { background: #F8FAFC; border-color: var(--gray-600); }
  .module-card h4 { font-size: 13px; font-weight: 700; margin-bottom: 8px; }
  .module-card ul { list-style: none; padding: 0; }
  .module-card ul li { font-size: 12px; color: var(--gray-600); padding: 2px 0; }
  .module-card ul li::before { content: '→ '; color: var(--gray-600); }

  /* DIAGRAMS */
  .diagram-wrapper { background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 12px; padding: 32px; margin: 24px 0; overflow-x: auto; }
  .diagram-title { font-size: 13px; font-weight: 600; color: var(--gray-600); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; }

  /* USER STORIES */
  .us-grid { display: flex; flex-direction: column; gap: 20px; }
  .us-card { border: 1px solid var(--gray-200); border-radius: 12px; overflow: hidden; }
  .us-header { padding: 16px 24px; display: flex; align-items: center; gap: 16px; background: var(--gray-50); }
  .us-id { background: var(--primary); color: white; font-weight: 700; font-size: 12px; padding: 4px 10px; border-radius: 6px; white-space: nowrap; }
  .us-title { font-weight: 600; font-size: 15px; }
  .us-epic { margin-left: auto; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 10px; white-space: nowrap; }
  .epic-leads { background: #EDE9FF; color: var(--primary); }
  .epic-dialogs { background: #ECFDF5; color: #16A34A; }
  .epic-trigger { background: #FFF7ED; color: #EA580C; }
  .epic-chains { background: #FEF3C7; color: #D97706; }
  .epic-bots { background: #F0FDF4; color: #15803D; }
  .epic-ai { background: #EFF6FF; color: #1D4ED8; }
  .epic-settings { background: #F8FAFC; color: #475569; }
  .us-body { padding: 20px 24px; }
  .us-story { font-size: 14px; color: var(--gray-800); font-style: italic; margin-bottom: 16px; padding: 12px 16px; background: #FAFAFA; border-left: 3px solid var(--primary); border-radius: 0 8px 8px 0; }
  .us-ac-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--gray-600); margin-bottom: 10px; }
  .us-ac-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .us-ac-list li { font-size: 13px; display: flex; align-items: flex-start; gap: 8px; }
  .us-ac-list li::before { content: '✓'; color: var(--green); font-weight: 700; flex-shrink: 0; margin-top: 1px; }

  /* DATA MODEL */
  .entity-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .entity-card { border: 1px solid var(--gray-200); border-radius: 10px; overflow: hidden; }
  .entity-header { background: var(--primary); color: white; padding: 12px 16px; font-weight: 700; font-size: 14px; }
  .entity-body { padding: 16px; }
  .field { display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--gray-100); font-size: 12px; }
  .field:last-child { border-bottom: none; }
  .field-name { font-weight: 500; color: var(--gray-800); }
  .field-type { color: var(--gray-600); font-family: monospace; }

  /* INTEGRATIONS */
  .int-section { margin-bottom: 32px; }
  .int-section-title { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--gray-600); margin-bottom: 12px; padding-bottom: 8px; border-bottom: 2px solid var(--gray-200); }
  .int-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .int-tag { padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 500; border: 1px solid; }
  .int-tag.active { background: #ECFDF5; border-color: #86EFAC; color: #16A34A; }
  .int-tag.available { background: var(--gray-50); border-color: var(--gray-200); color: var(--gray-600); }
  .int-tag.premium { background: #FFF7ED; border-color: #FED7AA; color: #EA580C; }

  /* TABLE */
  .data-table { width: 100%; border-collapse: collapse; margin-top: 16px; font-size: 13px; }
  .data-table th { background: var(--gray-800); color: white; padding: 10px 14px; text-align: left; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
  .data-table td { padding: 10px 14px; border-bottom: 1px solid var(--gray-200); vertical-align: top; }
  .data-table tr:hover td { background: var(--gray-50); }

  /* BOTTLENECKS */
  .issue-card { border-radius: 10px; padding: 20px; margin-bottom: 16px; border-left: 4px solid; }
  .issue-card.critical { background: #FEF2F2; border-color: #EF4444; }
  .issue-card.medium { background: #FFFBEB; border-color: #F59E0B; }
  .issue-card.growth { background: #ECFDF5; border-color: var(--green); }
  .issue-card h4 { margin: 0 0 8px; font-size: 14px; font-weight: 600; }
  .issue-card p { font-size: 13px; color: var(--gray-600); margin: 0; }
  .severity { display: inline-block; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 4px; text-transform: uppercase; margin-bottom: 8px; }
  .severity.critical { background: #EF4444; color: white; }
  .severity.medium { background: #F59E0B; color: white; }
  .severity.growth { background: var(--green); color: white; }

  /* SUBSCRIPTION */
  .plan-card { background: linear-gradient(135deg, var(--primary), #9F67FF); color: white; border-radius: 16px; padding: 32px; display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 24px; }
  .plan-stat { }
  .plan-stat-label { opacity: 0.7; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
  .plan-stat-value { font-size: 24px; font-weight: 700; }
  .plan-stat-sub { font-size: 12px; opacity: 0.7; }

  /* USE CASES */
  .uc-table { width: 100%; border-collapse: collapse; margin-top: 16px; font-size: 13px; }
  .uc-table th { background: var(--gray-800); color: white; padding: 10px 14px; text-align: left; font-weight: 600; }
  .uc-table td { padding: 10px 14px; border-bottom: 1px solid var(--gray-200); vertical-align: top; }
  .uc-table .actor { font-weight: 600; color: var(--primary); }
  .uc-table .priority-high { color: #EF4444; font-weight: 600; }
  .uc-table .priority-med { color: #F59E0B; font-weight: 600; }
  .uc-table .priority-low { color: var(--green); font-weight: 600; }

  /* NAV */
  .toc { background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 12px; padding: 28px; margin: 32px 40px; }
  .toc h3 { margin: 0 0 16px; font-size: 16px; }
  .toc ol { padding-left: 20px; columns: 2; column-gap: 40px; }
  .toc li { margin-bottom: 8px; font-size: 13px; }
  .toc a { color: var(--primary); text-decoration: none; }
  .toc a:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .plan-card { grid-template-columns: 1fr; }
    .toc ol { columns: 1; }
    .container { padding: 0 20px; }
    .cover { padding: 40px 20px; }
  }
</style>
</head>
